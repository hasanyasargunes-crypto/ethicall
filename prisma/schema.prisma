generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                 String         @id @default(cuid())
  name               String
  slug               String         @unique
  domain             String         @unique
  emailDomain        String?
  logoUrl            String?
  primaryColor       String?        @default("#059669")
  secondaryColor     String?        @default("#047857")
  fontFamily         String?        @default("Inter")
  plan               Plan           @default(TRIAL)
  billingPeriod      BillingPeriod  @default(MONTHLY)
  planStartDate      DateTime?
  planEndDate        DateTime?
  locale             String         @default("tr")
  slaAcknowledgeDays Int            @default(7)
  slaResolveDays     Int            @default(90)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  reports       Report[]
  users         User[]
  categories    Category[]
  formTemplates FormTemplate[]
  teamInvites   TeamInvite[]
}

enum Plan {
  TRIAL
  ESSENTIAL
  SHIELD
  VAULT
}

enum BillingPeriod {
  MONTHLY
  YEARLY
}

enum FormStatus {
  DRAFT
  LIVE
}

model User {
  id             String   @id @default(cuid())
  email          String
  name           String
  passwordHash   String
  role           UserRole @default(REVIEWER)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  createdAt      DateTime     @default(now())

  assignedReports Report[]  @relation("AssignedTo")
  comments        Message[]
  auditLogs       AuditLog[]

  @@unique([email, organizationId])
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  REVIEWER
}

model Category {
  id             String       @id @default(cuid())
  name_tr        String
  name_en        String
  description_tr String?
  description_en String?
  icon           String?
  isActive       Boolean      @default(true)
  sortOrder      Int          @default(0)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  reports      Report[]
  formTemplate FormTemplate?
}

model FormTemplate {
  id             String       @id @default(cuid())
  name           String       @default("Isimsiz Form")
  categoryId     String       @unique
  category       Category     @relation(fields: [categoryId], references: [id])
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  fields         Json         @default("[]")
  status         FormStatus   @default(DRAFT)
  publicToken    String?      @unique
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @default(now()) @updatedAt
}

model Report {
  id            String       @id @default(cuid())
  trackingCode  String       @unique
  reporterEmail String
  reporterEmailVerified Boolean @default(false)

  categoryId  String
  category    Category     @relation(fields: [categoryId], references: [id])
  title       String
  description String       @db.Text
  formData    Json?
  severity    Severity     @default(MEDIUM)
  isAnonymous Boolean      @default(true)

  status   ReportStatus @default(NEW)
  priority Priority     @default(MEDIUM)

  assignedToId String?
  assignedTo   User?    @relation("AssignedTo", fields: [assignedToId], references: [id])

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  acknowledgedAt DateTime?
  resolvedAt     DateTime?
  slaAckDeadline DateTime
  slaResDeadline DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attachments Attachment[]
  messages    Message[]
  auditLogs   AuditLog[]

  @@index([organizationId, status])
  @@index([trackingCode])
}

enum ReportStatus {
  NEW
  ACKNOWLEDGED
  UNDER_REVIEW
  INVESTIGATING
  RESOLVED
  CLOSED
  DISMISSED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Attachment {
  id         String   @id @default(cuid())
  reportId   String
  report     Report   @relation(fields: [reportId], references: [id])
  fileName   String
  fileUrl    String
  fileSize   Int
  mimeType   String
  uploadedBy String
  createdAt  DateTime @default(now())
}

model Message {
  id         String     @id @default(cuid())
  reportId   String
  report     Report     @relation(fields: [reportId], references: [id])
  content    String     @db.Text
  senderType SenderType
  senderId   String?
  sender     User?      @relation(fields: [senderId], references: [id])
  isRead     Boolean    @default(false)
  createdAt  DateTime   @default(now())
}

enum SenderType {
  REPORTER
  STAFF
  SYSTEM
}

model AuditLog {
  id        String   @id @default(cuid())
  reportId  String?
  report    Report?  @relation(fields: [reportId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  details   Json?
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([reportId])
}

model TeamInvite {
  id             String       @id @default(cuid())
  email          String
  name           String
  role           UserRole     @default(REVIEWER)
  token          String       @unique
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  invitedById    String?
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([token])
  @@index([email, organizationId])
}

model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  orgSlug   String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, code])
}
